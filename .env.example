# GT Café house terminal (E11) — server-only secrets. Never NEXT_PUBLIC.
# Copy to .env.local for local dev; set the same three in Vercel for production.
# With none of these set the terminal route answers 503 TERMINAL_OFFLINE and the
# build still passes keyless — nothing here is required to build.

# Groq API key (free tier) — powers the terminal's chat model, server-side only.
# Create one at https://console.groq.com/keys
GROQ_API_KEY=

# Upstash Redis REST URL — backs the terminal's rate limiting.
# Create a Redis database at https://console.upstash.com and copy its REST URL.
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token — the read/write token for the database above.
# ALSO backs the anonymized event pipeline (page-view + chat counters, question
# ring buffer). No extra service needed — same Redis as the rate limiter.
UPSTASH_REDIS_REST_TOKEN=

# ── Admin terminal (E11) — server-only. Absent → admin login returns 503,
# never a bypass; the public site is unaffected. ──────────────────────────────

# Scrypt digest of the admin passphrase, formatted `salt:hash` (both hex).
# Generate locally (plaintext is never stored/logged):
#   node scripts/hash-admin-passphrase.mjs
ADMIN_PASSPHRASE_SCRYPT=

# HMAC-SHA256 key that signs admin session cookies. Use a long random value:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=
