# GT Café house terminal (E11) — server-only secrets. Never NEXT_PUBLIC.
# Copy to .env.local for local dev; set the same three in Vercel for production.
# With none of these set the terminal route answers 503 TERMINAL_OFFLINE and the
# build still passes keyless — nothing here is required to build.

# Groq API key (free tier) — powers the terminal's chat model, server-side only.
# Create one at https://console.groq.com/keys
GROQ_API_KEY=

# Upstash Redis REST URL — backs the terminal's rate limiting.
# Create a Redis database at https://console.upstash.com and copy its REST URL.
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token — the read/write token for the database above.
UPSTASH_REDIS_REST_TOKEN=
